<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TrustTunnelGui.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer x:Name="MainScroll"
                  IsScrollInertiaEnabled="True"
                  PointerWheelChanged="MainScroll_PointerWheelChanged">
        <Grid Padding="32" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Настройки" FontSize="28" FontWeight="SemiBold"/>

            <Expander Grid.Row="1" Header="Бинари" IsExpanded="True" HorizontalAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <TextBlock x:Name="ExePathText" FontFamily="Consolas" TextWrapping="Wrap"/>
                    <TextBlock x:Name="WintunPathText" FontFamily="Consolas" TextWrapping="Wrap"/>
                    <Button Content="Открыть папку конфигов" Click="OpenConfigs_Click"/>
                </StackPanel>
            </Expander>

            <Expander Grid.Row="2" Header="Автозапуск и поведение" IsExpanded="True" HorizontalAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <ToggleSwitch x:Name="AutostartToggle" Header="Запускать при входе в систему"
                                  Toggled="Autostart_Toggled"
                                  ToolTipService.ToolTip="Создаёт задачу в Планировщике с правами админа — без UAC-промпта при логине."/>
                    <ToggleSwitch x:Name="AutoConnectToggle" Header="Автоматически подключаться при запуске"
                                  Toggled="AutoConnect_Toggled"/>
                    <ToggleSwitch x:Name="StartHiddenToggle" Header="Запускать свёрнутым в трей"
                                  Toggled="StartHidden_Toggled"/>
                    <ToggleSwitch x:Name="ResetAdapterToggle" Header="Сбрасывать сетевой адаптер перед подключением"
                                  Toggled="ResetAdapter_Toggled"
                                  ToolTipService.ToolTip="Отключает и включает активный физический сетевой адаптер перед запуском туннеля. Очищает остатки от других VPN-клиентов. По умолчанию ВЫКЛЮЧЕНО — при включённой опции клиент может падать с ошибкой 'Couldn't detect active network interface' если адаптер не успел подняться."/>
                </StackPanel>
            </Expander>

            <Expander Grid.Row="3" Header="О программе" HorizontalAlignment="Stretch">
                <StackPanel Padding="8" Spacing="6">
                    <TextBlock Text="TrustTunnel GUI" FontWeight="SemiBold"/>
                    <TextBlock Text="WinUI 3 враппер для официального CLI-клиента TrustTunnel." Opacity="0.7"/>
                    <HyperlinkButton Content="github.com/TrustTunnel/TrustTunnelClient"
                                     NavigateUri="https://github.com/TrustTunnel/TrustTunnelClient"/>
                </StackPanel>
            </Expander>
        </Grid>
    </ScrollViewer>
</Page>
