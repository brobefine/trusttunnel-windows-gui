<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TrustTunnelGui.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <Grid Padding="32" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Настройки" FontSize="28" FontWeight="SemiBold"/>

            <Expander Grid.Row="1" Header="Бинари" IsExpanded="True" HorizontalAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <TextBlock x:Name="ExePathText" FontFamily="Consolas" TextWrapping="Wrap"/>
                    <TextBlock x:Name="WintunPathText" FontFamily="Consolas" TextWrapping="Wrap"/>
                    <Button Content="Открыть папку конфигов" Click="OpenConfigs_Click"/>
                </StackPanel>
            </Expander>

            <Expander Grid.Row="2" Header="Windows-сервис" IsExpanded="True" HorizontalAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <TextBlock TextWrapping="Wrap" Opacity="0.7"
                               Text="Установка регистрирует сервис с активным профилем. Требует прав администратора."/>
                    <ComboBox x:Name="ServiceProfileBox" Header="Профиль для сервиса"
                              DisplayMemberPath="Name" MinWidth="320"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Установить сервис" Click="ServiceInstall_Click"
                                Style="{ThemeResource AccentButtonStyle}"/>
                        <Button Content="Удалить сервис" Click="ServiceUninstall_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="ServiceOutput" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Expander>

            <Expander Grid.Row="3" Header="О программе" HorizontalAlignment="Stretch">
                <StackPanel Padding="8" Spacing="6">
                    <TextBlock Text="TrustTunnel GUI" FontWeight="SemiBold"/>
                    <TextBlock Text="WinUI 3 враппер для официального CLI-клиента TrustTunnel." Opacity="0.7"/>
                    <HyperlinkButton Content="github.com/TrustTunnel/TrustTunnelClient"
                                     NavigateUri="https://github.com/TrustTunnel/TrustTunnelClient"/>
                </StackPanel>
            </Expander>
        </Grid>
    </ScrollViewer>
</Page>
