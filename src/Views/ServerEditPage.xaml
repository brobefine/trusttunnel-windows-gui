<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TrustTunnelGui.Views.ServerEditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <Grid Padding="32" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Редактирование сервера" FontSize="24" FontWeight="SemiBold"/>
                <Button Grid.Column="1" Content="Экспорт TOML" Click="Export_Click"/>
                <Button Grid.Column="2" Content="Сохранить" Click="Save_Click" Style="{ThemeResource AccentButtonStyle}"/>
            </Grid>

            <!-- Basic -->
            <Expander Grid.Row="1" Header="Основное" IsExpanded="True" HorizontalAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <TextBox Header="Имя профиля" Text="{x:Bind P.Name, Mode=TwoWay}"/>
                    <ComboBox Header="Уровень логов" SelectedItem="{x:Bind P.LogLevel, Mode=TwoWay}">
                        <x:String>error</x:String>
                        <x:String>warn</x:String>
                        <x:String>info</x:String>
                        <x:String>debug</x:String>
                        <x:String>trace</x:String>
                    </ComboBox>
                    <ComboBox Header="VPN режим" SelectedItem="{x:Bind P.VpnMode, Mode=TwoWay}">
                        <x:String>general</x:String>
                        <x:String>strict</x:String>
                    </ComboBox>
                </StackPanel>
            </Expander>

            <!-- Endpoint -->
            <Expander Grid.Row="2" Header="Endpoint (сервер)" IsExpanded="True" HorizontalAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <TextBox Header="Hostname (TLS SNI)" Text="{x:Bind P.Hostname, Mode=TwoWay}"
                             PlaceholderText="vpn.example.com"/>
                    <TextBox Header="Адреса (по одному в строке, ip[:port])"
                             Text="{x:Bind P.Addresses, Mode=TwoWay}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                             PlaceholderText="203.0.113.1:443"/>
                    <ToggleSwitch Header="IPv6 поддержка" IsOn="{x:Bind P.HasIpv6, Mode=TwoWay}"/>
                    <TextBox Header="Username" Text="{x:Bind P.Username, Mode=TwoWay}"/>
                    <PasswordBox Header="Password" Password="{x:Bind P.Password, Mode=TwoWay}"/>
                    <TextBox Header="Client Random (опц., hex)" Text="{x:Bind P.ClientRandom, Mode=TwoWay}"/>
                    <ToggleSwitch Header="Пропустить проверку TLS-сертификата (небезопасно)"
                                  IsOn="{x:Bind P.SkipVerification, Mode=TwoWay}"/>
                    <TextBox Header="Сертификат (PEM, опц.)" Text="{x:Bind P.Certificate, Mode=TwoWay}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                             FontFamily="Consolas"/>
                    <ComboBox Header="Транспорт" SelectedItem="{x:Bind P.UpstreamProtocol, Mode=TwoWay}">
                        <x:String>http2</x:String>
                        <x:String>http3</x:String>
                    </ComboBox>
                    <ComboBox Header="Резервный транспорт" SelectedItem="{x:Bind P.UpstreamFallbackProtocol, Mode=TwoWay}">
                        <x:String></x:String>
                        <x:String>http2</x:String>
                        <x:String>http3</x:String>
                    </ComboBox>
                    <ToggleSwitch Header="Anti-DPI" IsOn="{x:Bind P.AntiDpi, Mode=TwoWay}"/>
                </StackPanel>
            </Expander>

            <!-- Killswitch -->
            <Expander Grid.Row="3" Header="Killswitch" HorizontalAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <ToggleSwitch Header="Включить killswitch" IsOn="{x:Bind P.KillswitchEnabled, Mode=TwoWay}"/>
                    <TextBox Header="Разрешённые порты (через запятую)"
                             Text="{x:Bind P.KillswitchAllowPorts, Mode=TwoWay}"
                             PlaceholderText="53, 443"/>
                </StackPanel>
            </Expander>

            <!-- Crypto -->
            <Expander Grid.Row="4" Header="Криптография и DNS" HorizontalAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <ToggleSwitch Header="Post-quantum key exchange"
                                  IsOn="{x:Bind P.PostQuantumGroupEnabled, Mode=TwoWay}"/>
                    <TextBox Header="DNS-апстримы (по одному в строке)"
                             Text="{x:Bind P.DnsUpstreams, Mode=TwoWay}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                             FontFamily="Consolas"
                             PlaceholderText="tls://1.1.1.1&#x0a;https://dns.google/dns-query"/>
                </StackPanel>
            </Expander>

            <!-- Split tunneling -->
            <Expander Grid.Row="5" Header="Split tunneling (исключения)" HorizontalAlignment="Stretch">
                <StackPanel Spacing="8" Padding="8">
                    <TextBlock Opacity="0.7" FontSize="12"
                               Text="Домены/CIDR/IP — по одному в строке. Например: *.example.com, 192.168.0.0/16"/>
                    <TextBox Text="{x:Bind P.Exclusions, Mode=TwoWay}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"
                             FontFamily="Consolas"/>
                </StackPanel>
            </Expander>

            <!-- TUN listener -->
            <Expander Grid.Row="6" Header="TUN-листенер (системный VPN)" IsExpanded="True" HorizontalAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <ToggleSwitch Header="Включить TUN" IsOn="{x:Bind P.TunEnabled, Mode=TwoWay}"/>
                    <TextBox Header="Bound interface (опц.)" Text="{x:Bind P.TunBoundIf, Mode=TwoWay}"/>
                    <TextBox Header="Маршруты включения (по одному)"
                             Text="{x:Bind P.TunIncludedRoutes, Mode=TwoWay}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" FontFamily="Consolas"/>
                    <TextBox Header="Маршруты исключения (по одному)"
                             Text="{x:Bind P.TunExcludedRoutes, Mode=TwoWay}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" FontFamily="Consolas"/>
                </StackPanel>
            </Expander>

            <!-- SOCKS5 listener -->
            <Expander Grid.Row="7" Header="SOCKS5-листенер" HorizontalAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <ToggleSwitch Header="Включить SOCKS5" IsOn="{x:Bind P.Socks5Enabled, Mode=TwoWay}"/>
                    <TextBox Header="Адрес" Text="{x:Bind P.Socks5Address, Mode=TwoWay}"
                             PlaceholderText="127.0.0.1:1080"/>
                    <TextBox Header="Username (опц.)" Text="{x:Bind P.Socks5Username, Mode=TwoWay}"/>
                    <PasswordBox Header="Password (опц.)" Password="{x:Bind P.Socks5Password, Mode=TwoWay}"/>
                </StackPanel>
            </Expander>

            <InfoBar x:Name="StatusBar" Grid.Row="8" IsClosable="True" IsOpen="False"/>
        </Grid>
    </ScrollViewer>
</Page>
